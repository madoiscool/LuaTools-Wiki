ion":[[182,4]]}}}],["script",{"_index":21,"t":{"9":{"position":[[9,7]]},"11":{"position":[[87,6]]}}}],["server",{"_index":45,"t":{"11":{"position":[[201,7]]},"21":{"position":[[29,8]]}}}],["specif",{"_index":9,"t":{"5":{"position":[[5,8]]}}}],["speed",{"_index":50,"t":{"21":{"position":[[52,7]]}}}],["start",{"_index":38,"t":{"11":{"position":[[139,6]]}}}],["stay",{"_index":2,"t":{"1":{"position":[[20,4]]}}}],["steam",{"_index":48,"t":{"21":{"position":[[23,5]]}}}],["steamtool",{"_index":44,"t":{"11":{"position":[[190,10]]}}}],["step",{"_index":17,"t":{"7":{"position":[[0,4],[8,4]]}}}],["through",{"_index":16,"t":{"5":{"position":[[64,7]]}}}],["tri",{"_index":32,"t":{"11":{"position":[[48,6]]}}}],["uncap",{"_index":49,"t":{"21":{"position":[[43,8]]}}}],["up",{"_index":3,"t":{"1":{"position":[[25,2]]}}}],["updat",{"_index":35,"t":{"11":{"position":[[100,7]]}}}],["without",{"_index":41,"t":{"11":{"position":[[164,7]]}}}],["work",{"_index":39,"t":{"11":{"position":[[146,7]]}}}],["written",{"_index":26,"t":{"9":{"position":[[66,7]]}}}]],"pipeline":["stemmer"]}},{"documents":[],"index":{"version":"2.3.9","fields":["t"],"fieldVectors":[],"invertedIndex":[],"pipeline":["stemmer"]}},{"documents":[{"i":2,"t":"Join the discord to stay up to date about everything LuaTools (and everything else that might entail). Things break every now and then and we have to fix it, so it is recommended to join to stay up to date :)","s":"Discord (Recommended)","u":"/docs/luatools/discord","h":"","p":1},{"i":4,"t":"Click here to join our Discord server","s":"Join the Community","u":"/docs/luatools/discord","h":"#join-the-community","p":1},{"i":6,"t":"Game-specific fixes, online patches, and DRM bypasses available through LuaTools. To apply a fix: open the game's Steam store page → click the LuaTools icon → open the Fixes menu. Coming Soon Individual game fix pages are being added. Check the Discord for game-specific help in the meantime.","s":"Game Fixes","u":"/docs/luatools/fixes","h":"","p":5},{"i":8,"t":"Step-by-step guides for getting the most out of LuaTools. Coming Soon Guides are being written. Join the Discord to ask questions while this section is built out.","s":"Guides","u":"/docs/luatools/guides","h":"","p":7},{"i":10,"t":"LuaTools scripts extend the plugin's functionality with community-written automations and helpers. Coming Soon Script documentation is being written. Join the Discord for the latest.","s":"Scripts","u":"/docs/luatools/scripts","h":"","p":9},{"i":12,"t":"Getting the \"No Internet Connection\" erro while trying to download/update a game? This script force updates your manifests so the download starts working instantly without having to rely on steamtools servers to fetch them for you. irm \"https://luatools.vercel.app/manifests.ps1\" | iex Run the above in PowerShell and follow the prompts.","s":"\"No Internet Connection\" Fix (Manifest Updater)","u":"/docs/luatools/scripts/manifest-updater","h":"","p":11},{"i":14,"t":"When you run the script, you'll be asked to pick a mode: Mode API Key Required How it works Github Mirror No GitHub mirror only. Fails if a manifest isn't there. Morrenus Yes (Morrenus) Tries GitHub first, falls back to Morrenus on 404. ManifestHub Yes (ManifestHub) Tries GitHub first, falls back to ManifestHub on 404. If you're unsure which to pick, try option 1 first and if depots come up as missing try option 2 or 3. I reccomend option 2 (morrenus) — it has the best coverage and a free API key.","s":"Modes","u":"/docs/luatools/scripts/manifest-updater","h":"#modes","p":11},{"i":16,"t":"Both keys are free. Morrenus ManifestHub Go to manifest.morrenus.xyz and log in with Discord Generate your key at manifest.morrenus.xyz/api-keys/user Copy the key and save it somewhere. This key will not be shown again so if you lose it you must generate a new one. Go to manifesthub1.filegear-sg.me, complete the captcha and \"generate API key\" Generate and copy your API key from the panel","s":"Getting an API Key","u":"/docs/luatools/scripts/manifest-updater","h":"#getting-an-api-key","p":11},{"i":18,"t":"Set these environment variables before running to automate the whole thing: Example: $env:MANIFEST_MODE = \"github+morrenus\" $env:MORRENUS_API_KEY = \"your morrenus api key here\" $env:APP_ID = \"1091500\" irm \"https://luatools.vercel.app/manifests.ps1\" | iex No prompts — it runs, downloads, and shows a summary. Variable Description $env:MANIFEST_MODE github / github+morrenus / github+manifesthub $env:MORRENUS_API_KEY Your Morrenus key (smm_...) $env:MH_API_KEY Your ManifestHub key $env:APP_ID Steam App ID to process (e.g. 1091500)","s":"Skip the Prompts (Advanced)","u":"/docs/luatools/scripts/manifest-updater","h":"#skip-the-prompts-advanced","p":11},{"i":20,"t":"Reads your Steam install path from the registry Reads Steam/config/stplug-in/<AppId>.lua for depot IDs Fetches manifest IDs from the SteamCMD API For each depot — skips if already downloaded, tries GitHub first, falls back if needed Downloads manifests to Steam/depotcache/ Shows a summary, then asks if you want to process another game When it's done you'll see: What would you like to do next? 1. Process another AppID 2. Done! (close PowerShell) Pick 1 to run another game without re-entering your key.","s":"What It Does","u":"/docs/luatools/scripts/manifest-updater","h":"#what-it-does","p":11},{"i":22,"t":"Download directly from Steam servers, with uncapped speeds.","s":"Steam Plugin","u":"/docs/luatools/steam-plugin/","h":"","p":21},{"i":24,"t":"Full Steam experience on all your added games (achievements, overlay, workshop, and more!) Free and unlimited access to some of the best manifest sources in the scene Online-fixes and DRM/launcher bypasses directly in the plugin Play most co-op games online thanks to the unsteam implementation Unlock (almost) any DLC – most games come with all the DLC when you add them And yes, even Denuvo games: simply get your drink served at pub's and enjoy your game!","s":"What You Get","u":"/docs/luatools/steam-plugin/","h":"#what-you-get","p":21},{"i":26,"t":"Ready to jump in? Check out our Get Started Guide to begin using the Steam Plugin.","s":"Getting Started","u":"/docs/luatools/steam-plugin/","h":"#getting-started","p":21},{"i":29,"t":"Run this in PowerShell (or execute this file): irm \"https://luatools.vercel.app/install-plugin.ps1\" | iex This will install SteamTools (asks before), the plugin loader, and the LuaTools plugin.","s":"Easy Method","u":"/docs/luatools/steam-plugin/get-started","h":"#easy-method","p":27},{"i":31,"t":"warning This method is for advanced users only. No support is provided.","s":"Manual Method","u":"/docs/luatools/steam-plugin/get-started","h":"#manual-method","p":27},{"i":33,"t":"Download here: https://steamtools.net/","s":"Step 1. Make sure you have SteamTools installed","u":"/docs/luatools/steam-plugin/get-started","h":"#step-1-make-sure-you-have-steamtools-installed","p":27},{"i":35,"t":"You will need to figure out what it is on your own. I recommend searching on YouTube for a LuaTools guide if you can't figure it out. danger They are not affiliated! If you are found to ask them about this, you will be permanently banned from both sides.","s":"Step 2. Install the plugin loader","u":"/docs/luatools/steam-plugin/get-started","h":"#step-2-install-the-plugin-loader","p":27},{"i":37,"t":"Download the latest plugin zip from the GitHub Releases. Then navigate to your Steam directory (where steam.exe is located, usually %ProgramFiles(x86)%\\Steam), go to the plugins folder, create a new folder (name it whatever you like), and extract the zip contents there. tip To find the plugins folder easily: Open Steam → click \"Steam\" in the top left → plugin loader → Plugins → Browse Local Files","s":"Step 3. Install the Plugin","u":"/docs/luatools/steam-plugin/get-started","h":"#step-3-install-the-plugin","p":27},{"i":39,"t":"\"Steam\" (top left) → plugin loader → Plugins → toggle Luatools → Save Changes","s":"Step 4. Enable it in the plugin loader settings","u":"/docs/luatools/steam-plugin/get-started","h":"#step-4-enable-it-in-the-plugin-loader-settings","p":27},{"i":41,"t":"Add a game: Go to its store page → \"Add via LuaTools\" on the right → \"Restart Steam\" Remove a game: Go to its store page → LuaTools icon → \"Remove via LuaTools\" → \"Restart Steam\" Apply a fix Go to its store page → LuaTools icon → \"Fixes menu\"","s":"Usage","u":"/docs/luatools/steam-plugin/get-started","h":"#usage","p":27}],"index":{"version":"2.3.9","fields":["t"],"fieldVectors":[["t/2",[0,2.317,1,1.34,2,3.97,3,3.201,4,3.97,5,3.97,6,1.034,7,3.016,8,2.432,9,3.016,10,3.016,11,1.76,12,2.432,13,0.688]],["t/4",[0,2.314,1,1.762,14,2.692,15,2.692,16,2.692]],["t/6",[1,0.999,6,1.111,11,2.428,13,0.739,14,1.526,17,1.929,18,3.24,19,1.812,20,2.247,21,2.247,22,1.812,23,2.247,24,2.247,25,1.812,26,2.613,27,2.247,28,0.676,29,1.812,30,2.613,31,1.812,32,1.812,33,1.141,34,1.526,35,2.247,36,1.526,37,1.812,38,1.812,39,2.247,40,2.247]],["t/8",[0,1.791,1,1.363,6,1.052,33,1.558,34,2.083,36,2.083,41,4.015,42,2.726,43,2.474,44,2.726,45,2.474,46,1.558,47,3.068,48,3.068,49,3.068]],["t/10",[0,1.791,1,1.363,6,1.052,33,1.558,34,2.083,36,2.083,45,3.238,50,2.726,51,3.068,52,3.068,53,3.068,54,3.068,55,2.474,56,3.068,57,3.068,58,2.474]],["t/12",[13,0.579,16,1.723,17,1.289,43,2.047,50,1.723,59,2.538,60,2.538,61,2.538,62,1.723,63,2.538,64,2.538,65,2.538,66,1.482,67,1.128,68,2.047,69,2.047,70,2.538,71,2.047,72,2.538,73,2.538,74,2.047,75,2.047,76,1.723,77,2.047,78,1.723,79,1.289,80,2.538,81,1.723,82,2.538,83,2.047]],["t/14",[3,1.388,13,0.393,33,0.874,46,0.874,50,1.169,62,2.474,66,1.005,69,1.388,79,0.874,84,1.388,85,2.141,86,2.655,87,1.55,88,1.55,89,1.721,90,2.127,91,2.655,92,1.721,93,1.721,94,2.474,95,2.141,96,2.614,97,2.141,98,2.141,99,2.655,100,2.201,101,1.721,102,1.721,103,3.242,104,1.388,105,1.388,106,1.721,107,2.141,108,1.721,109,1.721,110,1.388,111,1.721,112,1.169]],["t/16",[1,1.025,87,1.927,88,2.705,94,1.566,100,1.566,112,1.566,113,1.86,114,2.241